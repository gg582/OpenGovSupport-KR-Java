# Copy to `.env` and tweak. docker-compose picks them up automatically.
#
# Host port mapping
BACKEND_PORT=31777
FRONTEND_PORT=31778

# Backend runtime tuning (see src/backend/src/main/java/.../runtime/)
POOL_WORKERS=8
POOL_QUEUE=4096
POOL_FAST_THRESHOLD=4096
JSON_INDENT=false
JAVA_OPTS=-XX:+UseG1GC -XX:MaxRAMPercentage=75

# Container resource caps
BACKEND_CPUS=2.0
BACKEND_MEMORY=1024M
FRONTEND_CPUS=1.0
FRONTEND_MEMORY=512M
