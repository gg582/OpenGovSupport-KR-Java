# Copy to `.env` and tweak. docker-compose picks them up automatically.
#
# HTTPS / TLS
# Place TLS certificate files in CERTS_DIR:
#   ${CERTS_DIR}/cert.pem       — Cloudflare origin certificate (not fullchain)
#   ${CERTS_DIR}/privkey.pem    — private key
CERTS_DIR=./certs
HTTP_PORT=80
HTTPS_PORT=443

# Backend runtime tuning (see src/backend/src/main/java/.../runtime/)
POOL_WORKERS=8
POOL_QUEUE=4096
POOL_FAST_THRESHOLD=4096
JSON_INDENT=false
JAVA_OPTS=-XX:+UseG1GC -XX:MaxRAMPercentage=75

# Container resource caps
BACKEND_CPUS=2.0
BACKEND_MEMORY=1024M
FRONTEND_CPUS=1.0
FRONTEND_MEMORY=512M

# Frontend API Base URL (used in generated scripts)
NEXT_PUBLIC_API_BASE_URL=https://tyutya.top
# Your Hugging Face Token
HUGGINGFACE_TOKEN=

# LLM service resource caps
LLM_CPUS=2.0
LLM_MEMORY=2048M
